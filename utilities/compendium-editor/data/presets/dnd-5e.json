          { "value": "necromancy", "label": "Necromancy" },
          { "value": "transmutation", "label": "Transmutation" }
        ]},
        { "id": "casting-time", "label": "Casting Time", "type": "text", "required": true },
        { "id": "range", "label": "Range", "type": "text", "required": true },
        { "id": "components", "label": "Components", "type": "tags", "required": false },
        { "id": "duration", "label": "Duration", "type": "text", "required": true },
        { "id": "concentration", "label": "Concentration", "type": "boolean", "required": false },
        { "id": "damage", "label": "Damage / Effect", "type": "text", "required": false },
