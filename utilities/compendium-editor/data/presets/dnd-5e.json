        { "id": "actions", "label": "Actions", "type": "textarea", "required": false },
        { "id": "legendary-actions", "label": "Legendary Actions", "type": "textarea", "required": false }
      ]
    },
    {
      "id": "item",
      "label": "Item",
      "fields": [
        { "id": "item-type", "label": "Item Type", "type": "select", "required": true, "options": [
          { "value": "weapon", "label": "Weapon" },
