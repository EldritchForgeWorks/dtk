{
  "meta": {
    "systemId": "dnd-5e",
    "name": "Dungeons & Dragons 5th Edition",
    "description": "The world's most popular tabletop roleplaying game. Roll a d20, add your modifier, beat the DC.",
    "version": "5.0.0"
  },
  "dice": [
    {
      "id": "d20",
      "name": "d20 Check",
      "mechanic": "single-die",
      "sides": 20,
      "threshold": 10,
      "comparison": "gte",
      "explodes": false,
      "keepMode": null,
      "degrees": [
        { "id": "crit-success", "label": "Critical Success", "min": 20 },
        { "id": "success", "label": "Success", "min": 10 },
        { "id": "failure", "label": "Failure", "min": 2 },
        { "id": "crit-fail", "label": "Critical Failure", "min": 1 }
      ],
      "description": "Roll 1d20 + modifier against a Difficulty Class (DC). Natural 20 = critical success, natural 1 = critical failure."
    }
  ],
  "attributes": [
    { "id": "str", "label": "Strength", "type": "integer", "min": 1, "max": 30, "default": 10, "formula": "", "description": "Measures bodily power, athletic training, and the extent to which you can exert raw physical force." },
    { "id": "dex", "label": "Dexterity", "type": "integer", "min": 1, "max": 30, "default": 10, "formula": "", "description": "Measures agility, reflexes, and balance." },
    { "id": "con", "label": "Constitution", "type": "integer", "min": 1, "max": 30, "default": 10, "formula": "", "description": "Measures health, stamina, and vital force." },
    { "id": "int", "label": "Intelligence", "type": "integer", "min": 1, "max": 30, "default": 10, "formula": "", "description": "Measures mental acuity, accuracy of recall, and the ability to reason." },
    { "id": "wis", "label": "Wisdom", "type": "integer", "min": 1, "max": 30, "default": 10, "formula": "", "description": "Reflects how attuned you are to the world around you and represents perceptiveness and intuition." },
    { "id": "cha", "label": "Charisma", "type": "integer", "min": 1, "max": 30, "default": 10, "formula": "", "description": "Measures your ability to interact effectively with others; confidence and eloquence." }
  ],
  "skills": [
    { "id": "athletics", "label": "Athletics", "linkedAttributes": ["str"], "description": "Covers difficult situations in climbing, jumping, or swimming." },
    { "id": "acrobatics", "label": "Acrobatics", "linkedAttributes": ["dex"], "description": "Covers attempts to stay on your feet in tricky situations." },
    { "id": "sleight-of-hand", "label": "Sleight of Hand", "linkedAttributes": ["dex"], "description": "Covers pickpocketing and concealing items on your person." },
    { "id": "stealth", "label": "Stealth", "linkedAttributes": ["dex"], "description": "Covers attempts to conceal yourself from enemies." },
    { "id": "arcana", "label": "Arcana", "linkedAttributes": ["int"], "description": "Measures ability to recall lore about spells, magic items, and magical traditions." },
    { "id": "history", "label": "History", "linkedAttributes": ["int"], "description": "Measures ability to recall lore about historical events, legendary people, and ancient kingdoms." },
    { "id": "investigation", "label": "Investigation", "linkedAttributes": ["int"], "description": "Covers looking around for clues and making deductions." },
    { "id": "nature", "label": "Nature", "linkedAttributes": ["int"], "description": "Measures ability to recall lore about terrain, plants, animals, and weather." },
    { "id": "religion", "label": "Religion", "linkedAttributes": ["int"], "description": "Measures ability to recall lore about deities, rites, and religious hierarchies." },
    { "id": "animal-handling", "label": "Animal Handling", "linkedAttributes": ["wis"], "description": "Covers calming domesticated animals, keeping a mount from panicking, and intuiting an animal's intentions." },
    { "id": "insight", "label": "Insight", "linkedAttributes": ["wis"], "description": "Covers determining the true intentions of a creature." },
    { "id": "medicine", "label": "Medicine", "linkedAttributes": ["wis"], "description": "Covers stabilizing a dying companion or diagnosing an illness." },
    { "id": "perception", "label": "Perception", "linkedAttributes": ["wis"], "description": "Covers spotting, hearing, or otherwise detecting the presence of something." },
    { "id": "survival", "label": "Survival", "linkedAttributes": ["wis"], "description": "Covers following tracks, hunting, navigating, and predicting weather." },
    { "id": "deception", "label": "Deception", "linkedAttributes": ["cha"], "description": "Covers convincingly hiding the truth through statement, action, or disguise." },
    { "id": "intimidation", "label": "Intimidation", "linkedAttributes": ["cha"], "description": "Covers influencing someone through overt threats or hostile actions." },
    { "id": "performance", "label": "Performance", "linkedAttributes": ["cha"], "description": "Covers delighting an audience with music, dance, acting, storytelling, or other entertainment." },
    { "id": "persuasion", "label": "Persuasion", "linkedAttributes": ["cha"], "description": "Covers influencing someone or a group of people with tact, social graces, or good nature." }
  ],
  "derived": [
    { "id": "passive-perception", "label": "Passive Perception", "formula": "10 + @perception", "description": "Used when not actively searching; determines what you notice without trying." },
    { "id": "initiative", "label": "Initiative Bonus", "formula": "@dex_mod", "description": "Added to initiative rolls at the start of combat." },
    { "id": "proficiency-bonus", "label": "Proficiency Bonus", "formula": "ceil(@level / 4) + 1", "description": "Added to attack rolls, saving throws, and skill checks where proficient." }
  ],
  "resources": [
    { "id": "hit-points", "label": "Hit Points", "formula": "@hit-dice + (@con_mod * @level)", "recoverable": true, "description": "Represents a combination of physical and mental durability, the will to live, and luck." },
    { "id": "hit-dice", "label": "Hit Dice", "formula": "@level", "recoverable": true, "description": "Spent during short rests to recover hit points." },
    { "id": "spell-slots-1", "label": "Spell Slots (1st)", "formula": "", "recoverable": true, "description": "Resources spent to cast 1st-level spells." }
  ],
  "currencies": ["cp", "sp", "ep", "gp", "pp"],
