        { "id": "feature", "label": "Background Feature", "type": "textarea", "required": true }
      ]
    }
  ],
  "creation": {
    "id": "dnd-5e-creation",
    "mode": "steps",
    "steps": [
      {
        "id": "race",
        "label": "Choose a Race",
        "hint": "Your character's race grants racial traits, ability score increases, and other features.",
        "fields": [
          { "type": "content-grid", "id": "race-choice", "label": "Race", "contentTypeId": "race", "required": true }
        ]
      },
      {
        "id": "class",
        "label": "Choose a Class",
        "hint": "Your class is the primary definition of what your character can do.",
        "fields": [
          { "type": "content-grid", "id": "class-choice", "label": "Class", "contentTypeId": "class", "required": true }
        ]
      },
      {
        "id": "ability-scores",
        "label": "Determine Ability Scores",
        "hint": "Assign your six ability scores using the Standard Array, Point Buy, or rolling.",
        "fields": [
          { "type": "allocation", "id": "ability-allocation", "label": "Point Buy", "pool": "27", "targets": ["str", "dex", "con", "int", "wis", "cha"] }
        ]
      },
      {
        "id": "background",
        "label": "Choose a Background",
        "hint": "Your background provides proficiencies, languages, equipment, and a background feature.",
        "fields": [
          { "type": "content-grid", "id": "background-choice", "label": "Background", "contentTypeId": "background", "required": true }
        ]
      }
    ],
    "advancementTracks": [
      {
        "id": "standard",
        "label": "Standard Advancement",
        "xpTable": [0, 300, 900, 2700, 6500, 14000, 23000, 34000, 48000, 64000, 85000, 100000, 120000, 140000, 165000, 195000, 225000, 265000, 305000, 355000],
        "advancements": [
          { "id": "asi", "label": "Ability Score Improvement", "cost": 0, "unlockStep": "" }
        ]
      }
    ]
  },
