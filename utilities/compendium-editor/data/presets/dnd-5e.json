          { "value": "gargantuan", "label": "Gargantuan" }
        ]},
        { "id": "ac", "label": "Armor Class", "type": "number", "required": true, "min": 0, "max": 30 },
        { "id": "hp", "label": "Hit Points", "type": "text", "required": true },
        { "id": "speed", "label": "Speed", "type": "text", "required": true },
        { "id": "m-str", "label": "STR", "type": "number", "required": false, "min": 1, "max": 30 },
        { "id": "m-dex", "label": "DEX", "type": "number", "required": false, "min": 1, "max": 30 },
