        { "id": "benefit", "label": "Benefit", "type": "textarea", "required": true }
      ]
    },
    {
      "id": "background",
      "label": "Background",
      "fields": [
        { "id": "skill-proficiencies", "label": "Skill Proficiencies", "type": "tags", "required": true },
        { "id": "tool-proficiencies", "label": "Tool Proficiencies", "type": "tags", "required": false },
        { "id": "languages", "label": "Languages", "type": "tags", "required": false },
