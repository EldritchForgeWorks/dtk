          { "value": "abjuration", "label": "Abjuration" },
          { "value": "conjuration", "label": "Conjuration" },
          { "value": "divination", "label": "Divination" },
          { "value": "enchantment", "label": "Enchantment" },
          { "value": "evocation", "label": "Evocation" },
