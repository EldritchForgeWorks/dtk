{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true
  },
  "include": [
    "src/domain/**/*.ts",
    "src/ports/**/*.ts",
    "src/adapters/in-memory/**/*.ts",
    "src/AleaApi.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "tests",
    "src/index.ts",
    "src/adapters/foundry/**"
  ]
}
