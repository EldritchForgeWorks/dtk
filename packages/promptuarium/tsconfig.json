{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "lib": ["ESNext"],
    "paths": {
      "@eldritchforgeworks/dtk-types": ["../types/dist/index.d.ts"],
      "@eldritchforgeworks/dtk-types/*": ["../types/dist/*/index.d.ts"]
    }
  },
  "include": ["src/**/*.ts", "cli/**/*.ts", "tests/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
