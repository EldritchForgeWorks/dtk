{
  "name": "@eldritchforgeworks/dtk-promptuarium",
  "version": "0.1.0",
  "type": "module",
  "description": "DTK compendium compiler CLI — validates YAML Exemplar corpora against @eldritchforgeworks/dtk-types and compiles them to Foundry VTT LevelDB packs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EldritchForgeWorks/dtk.git",
    "directory": "packages/promptuarium"
  },
  "homepage": "https://github.com/EldritchForgeWorks/dtk#readme",
  "bugs": {
    "url": "https://github.com/EldritchForgeWorks/dtk/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "bin": {
    "promptuarium": "./dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "exports": {
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "build": "vite build && vite build --config vite.config.cli.ts"
  },
  "dependencies": {
    "classic-level": "^1.4.1",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@vitest/coverage-v8": "^2.0.0",
    "commander": "^12.1.0",
    "typescript": "^5.4.0",
    "vite": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "license": "MIT"
}
